<view style="text-align: center; color: #b9b9b9" wx:if="{{pageLoading}}">
  <t-loading theme="circular" size="40rpx" text="加载中..." inherit-color />
</view>
<view class="home-page-header">
  <view class="swiper-wrap">
    <t-swiper
      wx:if="{{imgSrcs.length > 0}}"
      current="{{current}}"
      autoplay="{{autoplay}}"
      duration="{{duration}}"
      interval="{{interval}}"
      height="420rpx"
      navigation="{{navigation}}"
      imageProps="{{swiperImageProps}}"
      list="{{imgSrcs}}"
      bind:click="navigateToActivityDetail"
    />
  </view>
</view>
<view class="home-page-container">
  <view class="home-page-tabs">
    <t-tabs
      t-class="t-tabs"
      t-class-active="tabs-external__active"
      t-class-item="tabs-external__item"
      value="{{selectedTabIndex}}"
      space-evenly="{{false}}"
      bind:change="handleTabChange"
    >
      <t-tab-panel
        wx:for="{{tabList}}"
        wx:for-index="index"
        wx:key="index"
        label="{{item.text}}"
        value="{{index}}"
      />
    </t-tabs>
  </view>

  <!-- 商品列表 - 使用原生组件 -->
  <view class="goods-list">
    <view
      class="goods-card"
      wx:for="{{goodsList}}"
      wx:key="spuId"
      data-index="{{index}}"
      bind:tap="navigateToGoodsDetail"
    >
      <image class="goods-thumb" src="{{item.primaryImage}}" mode="aspectFill" lazy-load />
      <view class="goods-info">
        <view class="goods-title">{{item.title}}</view>
        <view class="goods-tags" wx:if="{{item.spuTagList.length}}">
          <text class="goods-tag" wx:for="{{item.spuTagList}}" wx:for-item="tag" wx:key="title"
            >{{tag.title}}</text
          >
        </view>
        <view class="goods-price-row">
          <text class="goods-price">¥{{item.minSalePrice}}</text>
          <text class="goods-origin-price" wx:if="{{item.minLinePrice}}"
            >¥{{item.minLinePrice}}</text
          >
          <view class="goods-cart-btn" catchtap="handleAddCart" data-index="{{index}}">
            <t-icon prefix="wr" name="cartAdd" size="48rpx" color="#FA550F" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <load-more
    list-is-empty="{{!goodsList.length}}"
    status="{{goodsListLoadStatus}}"
    bind:retry="handleRetry"
  />
  <t-toast id="t-toast" />
  <t-dialog id="t-dialog" />
</view>
