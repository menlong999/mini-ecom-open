page {
  box-sizing: border-box;
  padding-bottom: calc(env(safe-area-inset-bottom) + 96rpx);
}

.t-tabs.t-tabs--top .t-tabs__scroll {
  border-bottom: none !important;
}

.home-page-header {
  background: var(--color-page-soft);
}

.home-page-container {
  background: var(--color-page);
}

.home-page-container,
.home-page-header {
  display: block;
  padding: 0 24rpx;
}

.home-page-header .t-search__input-container {
  border-radius: 32rpx !important;
  height: 64rpx !important;
}

.home-page-header .t-search__input {
  font-size: 28rpx !important;
  color: var(--color-text-secondary) !important;
}

.home-page-header .swiper-wrap {
  margin-top: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
}

.home-page-header .t-image__swiper {
  width: 100%;
  height: 420rpx;
}

.home-page-container .t-tabs {
  background: var(--color-page) !important;
}

.home-page-container .t-tabs .t-tabs-nav {
  background-color: transparent;
  line-height: 80rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.home-page-container .t-tabs .t-tabs-scroll {
  border: none !important;
}

/* 半个字 */
.home-page-container .tab.order-nav .order-nav-item.scroll-width {
  min-width: 165rpx;
}

.home-page-container .tab .order-nav-item.active {
  color: var(--color-primary) !important;
}

.home-page-container .tab .bottom-line {
  border-radius: 4rpx;
}

.home-page-container .tab .order-nav-item.active .bottom-line {
  background-color: var(--color-primary) !important;
}

.home-page-container .tabs-external__item {
  /* color: var(--color-text-secondary) !important; */
  font-size: 28rpx;
}

.home-page-container .tabs-external__active {
  color: var(--color-text) !important;
  font-size: 32rpx;
}

.home-page-container .tabs-external__track {
  /* background-color: var(--color-primary) !important; */
  height: 6rpx !important;
  border-radius: 4rpx !important;
  width: 48rpx !important;
}

.t-tabs.t-tabs--top .t-tabs__item,
.t-tabs.t-tabs--bottom .t-tabs__item {
  height: 86rpx !important;
}

.home-page-container .goods-list-container {
  background: var(--color-page) !important;
  margin-top: 16rpx;
}

.home-page-tabs {
  --td-tab-nav-bg-color: transparent;
  --td-tab-border-color: transparent;
  --td-tab-item-color: var(--color-text-secondary);
  --td-tab-track-color: var(--color-primary);
}

/* 商品列表样式 */
.goods-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 16rpx 0;
}

.goods-card {
  width: 342rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.goods-thumb {
  width: 100%;
  height: 342rpx;
  display: block;
}

.goods-info {
  padding: 16rpx 20rpx 20rpx;
}

.goods-title {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 36rpx;
  height: 72rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.goods-tag {
  color: var(--color-primary);
  font-size: 20rpx;
  border: 1rpx solid var(--color-primary);
  padding: 0 8rpx;
  border-radius: 16rpx;
  line-height: 30rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  margin-top: 8rpx;
  position: relative;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-price);
}

.goods-origin-price {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-decoration: line-through;
  margin-left: 8rpx;
}

.goods-cart-btn {
  position: absolute;
  right: 0;
  bottom: 0;
}
