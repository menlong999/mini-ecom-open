<block wx:if="{{isLogin}}">
  <!-- 购物车商品列表 -->
  <block wx:if="{{cartList.length > 0 || invalidList.length > 0}}">
    <!-- 有效商品列表 -->
    <view class="cart-list-wrap" wx:if="{{cartList.length > 0}}">
      <block wx:for="{{cartList}}" wx:key="skuId">
        <t-swipe-cell right-width="{{72}}">
          <view class="cart-item">
            <!-- 选中按钮 -->
            <view class="check-wrap" catchtap="handleGoodsSelect" data-goods="{{item}}">
              <t-icon
                size="40rpx"
                color="{{item.isSelected ? '#FA4126' : '#BBBBBB'}}"
                name="{{item.isSelected ? 'check-circle-filled' : 'circle'}}"
              />
            </view>

            <!-- 商品内容 -->
            <view class="content-wrap" bindtap="navigateToGoodsDetails" data-goods="{{item}}">
              <t-image
                src="{{item.thumb}}"
                mode="aspectFill"
                width="192rpx"
                height="192rpx"
                class="goods-image"
              />
              <view class="info-wrap">
                <view class="title">{{item.title}}</view>
                <view class="specs-wrap" wx:if="{{item.specs && item.specs.length}}">
                  <view class="specs-text">{{item.specs}}</view>
                </view>
                <view class="bottom-wrap">
                  <price
                    symbol="¥"
                    price="{{item.price}}"
                    fill="{{true}}"
                    decimalSmaller
                    class="price-class"
                    priceUnit="yuan"
                  />
                  <t-stepper
                    value="{{item.quantity}}"
                    min="{{1}}"
                    max="{{999}}"
                    theme="filled"
                    catchchange="handleQuantityChange"
                    data-goods="{{item}}"
                  />
                </view>
              </view>
            </view>
          </view>

          <!-- 右侧删除 -->
          <view slot="right" class="delete-btn" bindtap="handleDeleteConfirm" data-goods="{{item}}">
            删除
          </view>
        </t-swipe-cell>
      </block>
    </view>

    <!-- 失效商品列表 -->
    <block wx:if="{{invalidList.length > 0}}">
      <view class="invalid-goods-header">
        <text class="invalid-title">失效商品</text>
        <text class="clear-invalid" bind:tap="handleClearInvalid">清空失效商品</text>
      </view>
      <!-- 失效商品列表 -->
      <view class="cart-list-wrap invalid-list">
        <block wx:for="{{invalidList}}" wx:key="skuId">
          <t-swipe-cell right-width="{{72}}">
            <view class="cart-item opacity-50">
              <view class="content-wrap" bindtap="navigateToGoodsDetails" data-goods="{{item}}">
                <t-image src="{{item.thumb}}" mode="aspectFill" width="160rpx" height="160rpx" />
                <view class="info-wrap">
                  <view class="title">{{item.title}}</view>
                  <view class="specs-text margin-top-sm">失效商品</view>
                </view>
              </view>
            </view>
            <view
              slot="right"
              class="delete-btn"
              bindtap="handleDeleteConfirm"
              data-goods="{{item}}"
            >
              删除
            </view>
          </t-swipe-cell>
        </block>
      </view>
    </block>

    <view class="gap" />

    <!-- 结算栏 -->
    <cart-bar
      is-all-selected="{{isAllSelected}}"
      total-amount="{{totalAmount}}"
      total-goods-num="{{selectedGoodsCount}}"
      fixed="{{true}}"
      bottomHeight="{{110}}"
      bindhandleSelectAll="handleSelectAll"
      bindhandleToSettle="navigateToOrderConfirm"
    />
  </block>

  <!-- 购物车空态 -->
  <cart-empty wx:else bind:handleClick="navigateToHome" />
</block>
<block wx:else>
  <view class="empty-login-wrap">
    <image class="prompt-image" src="/assets/images/cart-empty.png" mode="aspectFit" />
    <view class="prompt-text">登录后才能看到购物车哦</view>
    <t-button bind:tap="navigateToLogin" theme="primary" size="large">立即登录</t-button>
  </view>
</block>

<t-toast id="t-toast" />
<t-dialog id="t-dialog" />
