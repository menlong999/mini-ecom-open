<view class="user-center-card">
  <!-- 未登录的情况 -->
  <block wx:if="{{currAuthStep === 1}}">
    <view class="user-center-card__header" bind:tap="handleUserCardClick">
      <t-avatar
        wx:if="{{userInfo.avatarUrl}}"
        image="{{userInfo.avatarUrl}}"
        class="user-center-card__header__avatar"
      />
      <view wx:else class="user-center-card__header__avatar avatar-placeholder">
        <t-icon name="user" size="44rpx" />
      </view>
      <view class="user-center-card__header__name">{{'请登录'}}</view>
    </view>
  </block>
  <!-- 已登录但未授权用户信息情况 -->
  <block wx:if="{{currAuthStep === 2}}">
    <view class="user-center-card__header" bind:tap="handleUserCardClick">
      <t-avatar
        wx:if="{{userInfo.avatarUrl}}"
        image="{{userInfo.avatarUrl}}"
        class="user-center-card__header__avatar"
      />
      <view wx:else class="user-center-card__header__avatar avatar-placeholder">
        <t-icon name="user" size="44rpx" />
      </view>
      <view class="user-center-card__header__name">{{userInfo.nickName || '微信用户'}}</view>
    </view>
  </block>
  <!-- 已登录且已经授权用户信息的情况 -->
  <block wx:if="{{currAuthStep === 3}}">
    <view class="user-center-card__header" bind:tap="handleUserCardClick">
      <t-avatar
        wx:if="{{userInfo.avatarUrl}}"
        t-class="avatar"
        mode="aspectFill"
        class="user-center-card__header__avatar"
        image="{{userInfo.avatarUrl}}"
      />
      <view wx:else class="user-center-card__header__avatar avatar-placeholder">
        <t-icon name="user" size="44rpx" />
      </view>
      <view class="user-center-card__header__name">{{userInfo.nickName || '微信用户'}}</view>
    </view>
  </block>
</view>
<view class="content-wrapper">
  <view class="order-group-wrapper">
    <t-order-group
      orderTagInfos="{{orderTagInfos}}"
      bind:onClickTop="handleAllOrderNav"
      bind:onClickItem="handleOrderNav"
    />
  </view>
  <view wx:for="{{menuData}}" wx:key="item" class="cell-box">
    <t-cell-group>
      <t-cell
        wx:for="{{item}}"
        wx:for-item="xitem"
        wx:for-index="xindex"
        wx:key="xindex"
        title="{{xitem.title}}"
        arrow="{{!xitem.icon}}"
        note="{{xitem.tit}}"
        data-type="{{xitem.type}}"
        bordered="{{false}}"
        bind:click="handleCellClick"
        t-class="t-cell-padding"
        t-class-note="order-group-note"
        t-class-left="order-group__left"
      >
        <t-icon name="{{xitem.icon}}" size="48rpx" slot="note" />
      </t-cell>
    </t-cell-group>
  </view>

  <view class="cell-box" wx:if="{{isAdmin}}">
    <t-cell-group>
      <t-cell
        title="商家工作台 (管理员)"
        url="/pages/admin/dashboard/index"
        t-class="t-cell-padding"
        t-class-left="order-group__left"
      >
        <t-icon name="shop" size="48rpx" slot="note" />
      </t-cell>
    </t-cell-group>
  </view>
</view>

<page-container
  wx:if="{{tenantFeatures.distributor}}"
  show="{{showQRCode}}"
  position="center"
  bind:clickoverlay="handleCloseQRCode"
  custom-style="background-color: transparent; display: flex; align-items: center; justify-content: center;"
>
  <view class="qr-code-popup">
    <view class="qr-code-title">我的二维码</view>
    <image class="qr-code-image" src="{{myQRCodeUrl}}" mode="widthFix" wx:if="{{myQRCodeUrl}}" />
    <view class="qr-code-loading" wx:else>生成中...</view>
    <view class="qr-code-desc">扫一扫上面的二维码图案，进入小程序</view>
    <view class="qr-code-close" bind:tap="handleCloseQRCode">关闭</view>
  </view>
</page-container>

<view class="footer__version" wx:if="{{versionNo !== ''}}">当前版本 {{versionNo}}</view>
<t-popup
  visible="{{showMakePhone}}"
  placement="bottom"
  bind:visible-change="handleCloseMakePhone"
  data-index="2"
>
  <view class="popup-content">
    <view class="popup-title border-bottom-1px" wx:if="{{customerServiceInfo.serviceTimeDuration}}">
      服务时间: {{customerServiceInfo.serviceTimeDuration}}
    </view>
    <view
      wx:if="{{customerServiceInfo.servicePhone}}"
      class="popup-phone {{showKefu ? 'border-bottom-1px' : ''}}"
      bind:tap="handleCall"
      >电话客服</view
    >
    <button class="popup-phone border-bottom-1px online" open-type="contact" wx:if="{{showKefu}}">
      在线客服
    </button>
    <view class="popup-close" bind:tap="handleCloseMakePhone">取消</view>
  </view>
</t-popup>
<t-toast id="t-toast" />
