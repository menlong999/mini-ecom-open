.user-center-card {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 480rpx;
  background-image: url('https://tdesign.gtimg.com/miniprogram/template/retail/template/user-center-bg-v1.png');
  background-size: cover;
  background-repeat: no-repeat;
  padding: 0 24rpx;
}

.user-center-card__header {
  margin-top: 192rpx;
  margin-bottom: 48rpx;
  height: 96rpx;
  line-height: 48rpx;
  display: flex;
  justify-content: flex-start;
  align-items: center;
  color: #333;
  position: relative;
}

.user-center-card__header__avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  overflow: hidden;
}

.user-center-card__header__name {
  font-size: 36rpx;
  line-height: 48rpx;
  color: #333;
  font-weight: bold;
  margin-left: 24rpx;
  margin-right: 16rpx;
}

.user-center-card__header__transparent {
  position: absolute;
  left: 0;
  top: 0;
  background-color: transparent;
  height: 100%;
  width: 100%;
}

.user-center-card__icon {
  line-height: 96rpx;
}

.content-wrapper {
  margin-top: 340rpx;
  position: relative;
  padding: 0 24rpx;
}

.main-content {
  height: 500rpx;
}

.order-group-wrapper {
  margin-bottom: 24rpx;
}

.cell-box {
  margin-bottom: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.cell-class {
  height: 100rpx;
  display: flex;
  align-items: center;
}

.icon-right {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}

.footer__version {
  text-align: center;
  margin-top: 50rpx;
  color: #999;
  margin-bottom: 50rpx;
  font-size: 24rpx;
  line-height: 32rpx;
}

.cell-box .t-cell-padding {
  padding: 24rpx 32rpx !important;
}

/* 按钮透明化 - 用于获取权限等场景 */
.transparent-btn {
  background: transparent;
  border: none;
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.transparent-btn::after {
  border: none;
}

/* QR Code Popup Styles */
.qr-code-popup {
  width: 600rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.qr-code-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.qr-code-image {
  width: 430rpx;
  height: 430rpx;
  background-color: #f5f5f5;
  /* 占位背景 */
  margin-bottom: 24rpx;
}

.qr-code-loading {
  width: 430rpx;
  height: 430rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #999;
  font-size: 28rpx;
  background-color: #f5f5f5;
  margin-bottom: 24rpx;
}

.qr-code-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
  text-align: center;
}

.qr-code-close {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border-top: 1rpx solid #e7e7e7;
  /* 增加可点击区域 */
  padding-top: 20rpx;
}

/* Service Popup Styles */
.popup-content {
  background-color: #f5f5f5;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
}

.popup-title {
  padding: 24rpx 32rpx;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  background-color: #fff;
  border-bottom: 1rpx solid #e7e7e7;
}

.popup-phone {
  background-color: #fff;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
}

.popup-phone.online {
  margin-bottom: 0;
  border-radius: 0;
}

.popup-phone.online::after {
  border: none;
}

.border-bottom-1px {
  border-bottom: 1rpx solid #e7e7e7;
}

.popup-close {
  margin-top: 16rpx;
  background-color: #fff;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  padding-bottom: constant(safe-area-inset-bottom);
  /* 兼容 iOS < 11.2 */
  padding-bottom: env(safe-area-inset-bottom);
  /* 兼容 iOS >= 11.2 */
}