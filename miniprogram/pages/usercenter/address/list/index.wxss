page {
  background: #f5f5f5;
  height: 100%;
}

.address-container {
  display: flex;
  flex-direction: column;
  padding-bottom: calc(env(safe-area-inset-bottom) + 180rpx);
}

/* 地址列表 */
.address-list {
  background-color: #fff;
}

.address-item {
  border-bottom: 1rpx solid #f0f0f0;
}

.address-item:last-child {
  border-bottom: none;
}

/* 地址内容区域 */
.address-content {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fff;
}

.address-check {
  width: 60rpx;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.address-info {
  flex: 1;
  min-width: 0;
}

.address-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.address-phone {
  font-size: 28rpx;
  color: #333;
}

.address-detail {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  line-height: 1.5;
}

.address-tag {
  display: inline-block;
  padding: 0 12rpx;
  height: 32rpx;
  line-height: 32rpx;
  font-size: 20rpx;
  border-radius: 16rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.default-tag {
  background: #ffece9;
  color: #fa4126;
}

.normal-tag {
  background: #f0f1ff;
  color: #5a66ff;
}

.address-text {
  font-size: 28rpx;
  color: #999;
  word-break: break-all;
}

.address-edit {
  padding: 20rpx 0 20rpx 20rpx;
  flex-shrink: 0;
}

/* 右滑删除 */
.swipe-delete {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 144rpx;
  height: 100%;
  background-color: #fa4126;
  color: #fff;
  font-size: 28rpx;
}

/* 空状态 */
.no-address {
  padding-top: 30vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 底部按钮 */
.bottom-fixed {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  border-top: 1rpx solid #e5e5e5;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 16rpx);
}

.btn-wrap {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.wx-address-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  background: #fff;
  border: 1rpx solid #ddd;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.create-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  background: #fa4126;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
}

.btn-disabled {
  background: #ccc !important;
  border-color: #ccc !important;
  color: #999 !important;
}

.footer-tip {
  text-align: center;
  font-size: 24rpx;
  color: #ff2525;
  margin-top: 12rpx;
}