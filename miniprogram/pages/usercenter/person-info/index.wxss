:host {
  background-color: var(--color-page);
}
page view {
  box-sizing: border-box;
}
.person-info {
  padding-top: 20rpx;
}

.person-info__btn {
  width: 100%;
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  padding: 18rpx 0;
  display: flex;
  align-self: center;
  justify-content: center;
}
.person-info__wrapper {
  width: 100%;
  padding: 0 32rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  position: absolute;
  bottom: 0;
  left: 0;
}

.avatarUrl {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50% !important;
  overflow: hidden;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  background: var(--color-primary-light);
  border: 1rpx solid var(--color-border);
  font-size: 22rpx;
}

.t-class-confirm {
  color: var(--color-primary) !important;
}

.person-info .order-group__left {
  margin-right: 0;
}
.person-info .t-cell-class {
  height: 112rpx;
}

/* 透明按钮，用于覆盖 cell */
.avatar-wrapper-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0; /* 完全透明 */
  z-index: 10;
  background: transparent;
}
/* 去除默认 button 边框 */
.avatar-wrapper-btn::after {
  border: none;
}

/* 手机号获取按钮，类似链接样式或普通文本 */
.phone-wrapper-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  font-size: 28rpx;
  color: var(--color-primary); /* 主题色，提示点击 */
  line-height: inherit;
  text-align: right; /* 靠右对齐 */
}
.phone-wrapper-btn::after {
  border: none;
}
