.stock-container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
  box-sizing: border-box;
}

.filter-bar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 16rpx;
  background: #fff;
  border-radius: 999rpx;
  border: 1rpx solid #e5e6eb;
  font-size: 24rpx;
  color: #333;
}

.filter-input {
  flex: 1;
  min-width: 240rpx;
}

.filter-clear {
  padding: 4rpx;
}

.list-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.spu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
}

.spu-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
}

.spu-stock {
  font-size: 24rpx;
  color: #666;
  font-weight: 400;
}

.sku-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.sku-row:first-child {
  border-top: none;
}

.sku-spec {
  font-size: 24rpx;
  color: #333;
}

.sku-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.sku-stock {
  font-size: 22rpx;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stock-warning {
  color: #e34d59;
  font-weight: 600;
}

.stock-add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  border: 1rpx solid #e1e1e1;
  background: #f4f4f4;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 16rpx 0;
}

.loading-wrap {
  padding: 24rpx 0;
  display: flex;
  justify-content: center;
}

.stock-popup {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 20rpx 32rpx;
}

.stock-popup-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}

.stock-popup-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 20rpx;
}
