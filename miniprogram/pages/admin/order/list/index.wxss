.order-list-container {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.status-tab {
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #666;
}

.status-tab.active {
  color: #0052d9;
  background: #e6eefb;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
}

.list-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.order-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #333;
}

.order-status {
  color: #0052d9;
}

.order-card__body {
  font-size: 24rpx;
  color: #666;
}

.order-goods-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.order-goods-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.order-goods-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.order-goods-main {
  flex: 1;
}

.order-goods-title {
  color: #333;
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.order-goods-specs {
  color: #999;
  font-size: 22rpx;
}

.order-goods-aside {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: #333;
  font-size: 24rpx;
}

.order-goods-price {
  font-weight: 600;
}

.order-goods-qty {
  color: #666;
}

.order-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.order-total {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-bottom: 8rpx;
  color: #333;
}

.order-logistics {
  color: #999;
}

.order-operator {
  color: #999;
  margin-top: 4rpx;
}

.order-card__actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.empty-tip {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  margin-top: 80rpx;
}
