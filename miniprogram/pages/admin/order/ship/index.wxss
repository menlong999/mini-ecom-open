.ship-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: var(--color-page);
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.textarea-label {
  font-size: 26rpx;
  color: var(--color-text);
  margin: 12rpx 0;
}

.t-textarea-wrapper {
  background: var(--color-page);
  border-radius: 8rpx;
  padding: 12rpx;
}

.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: var(--shadow-bar);
  z-index: 100;
}
