.ship-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.textarea-label {
  font-size: 26rpx;
  color: #333;
  margin: 12rpx 0;
}

.t-textarea-wrapper {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 12rpx;
}

.footer-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}
