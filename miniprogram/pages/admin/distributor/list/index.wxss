.page {
  min-height: 100vh;
  background: var(--color-page);
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.search-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.loading-wrap {
  padding: 48rpx 0;
  text-align: center;
  color: var(--color-text-muted);
}

.empty {
  text-align: center;
  color: var(--color-text-muted);
  padding: 32rpx 0;
  font-size: 26rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  box-shadow: var(--shadow-card);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.card-status {
  font-size: 24rpx;
  color: var(--color-warning);
}

.card-row {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
  word-break: break-all;
}

.card-actions {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.finish {
  text-align: center;
  color: var(--color-text-muted);
  padding: 20rpx 0;
  font-size: 24rpx;
}

.reject-panel {
  background: #fff;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  padding: 24rpx;
}

.reject-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.reject-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 16rpx;
}
