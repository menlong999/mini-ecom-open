.category-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
  background: var(--color-page);
  min-height: 100vh;
}

.status-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.status-tab {
  padding: 12rpx 20rpx;
  background: #fff;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.status-tab.active {
  color: var(--admin-primary);
  background: var(--admin-primary-light);
}

.toolbar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.list-wrapper {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.group-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.category-group {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
}

.group-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
  width: 100%;
}

.group-title {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.group-action {
  margin-left: auto;
}

.group-add-btn {
  --td-button-default-color: #fff;
  --td-button-default-bg-color: var(--color-success);
  --td-button-default-border-color: var(--color-success);
  --td-button-default-active-bg-color: var(--color-primary-pressed);
}

.group-items {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.category-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: var(--color-page);
}

.empty-sub {
  font-size: 24rpx;
  color: var(--color-text-muted);
  padding: 8rpx 0 4rpx;
}

.category-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.category-thumb {
  border-radius: 12rpx;
  overflow: hidden;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}

.category-meta {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 6rpx;
}

.category-actions {
  display: flex;
  gap: 12rpx;
}

.empty-tip {
  text-align: center;
  color: var(--color-text-muted);
  font-size: 24rpx;
  padding: 40rpx 0;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: var(--color-page);
  box-shadow: var(--shadow-bar);
}

.dialog-content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-page);
  padding: 16rpx;
  border-radius: 12rpx;
}

.form-picker-text {
  font-size: 26rpx;
  color: var(--color-text);
}
