.edit-container {
    padding: 24rpx;
    padding-bottom: 200rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.card {
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24rpx;
}

.card-title {
    font-size: 30rpx;
    font-weight: bold;
    color: #333;
}

.spec-item {
    background: #f9f9f9;
    padding: 16rpx;
    border-radius: 8rpx;
    margin-bottom: 16rpx;
}

.spec-row {
    display: flex;
    align-items: center;
    margin-bottom: 16rpx;
}

.spec-name-input {
    flex: 1;
    background: transparent;
}

.delete-icon {
    color: #999;
    margin-left: 16rpx;
}

.spec-values {
    display: flex;
    flex-wrap: wrap;
    gap: 16rpx;
}

.tags-values {
    margin-top: 16rpx;
}

.spec-tag {
    margin-bottom: 6rpx;
}

.add-value-btn {
    display: flex;
    align-items: center;
    font-size: 24rpx;
    color: #0052d9;
    padding: 4rpx 16rpx;
    background: #e6eefb;
    border-radius: 4rpx;
    cursor: pointer;
}

.sku-list {
    border-top: 1rpx solid #eee;
}

.sku-header {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 16rpx;
    padding: 12rpx 0;
    color: #999;
    font-size: 24rpx;
    border-bottom: 1rpx solid #eee;
}

.sku-header__spec {
    flex: 1;
}

.sku-header__image {
    width: 220rpx;
    flex-shrink: 0;
    text-align: left;
}

.sku-header__inputs {
    display: flex;
    gap: 16rpx;
    width: 320rpx;
}

.sku-header__inputs text {
    flex: 1;
    text-align: left;
}

.sku-input {
    box-sizing: border-box;
    border: 1rpx solid #e7e7e7;
    border-radius: 8rpx;
    background: #fff;
    padding: 16rpx 20rpx;
}

.sku-item {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 16rpx;
    padding: 16rpx 0;
    border-bottom: 1rpx solid #eee;
}

.sku-info {
    flex: 1;
}

.sku-image {
    width: 220rpx;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 12rpx;
}

.sku-thumb {
    width: 96rpx;
    height: 96rpx;
    border-radius: 12rpx;
    background: #f2f2f2;
    flex-shrink: 0;
}

.sku-thumb--placeholder {
    background: #f0f0f0;
}

.sku-image-actions {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
    align-items: flex-start;
}

.sku-specs {
    font-size: 26rpx;
    color: #333;
}

.sku-specs .divider {
    color: #ccc;
    margin: 0 4rpx;
}

.sku-inputs {
    display: flex;
    gap: 16rpx;
    width: 320rpx;
}

.sku-input {
    flex: 1;
    font-size: 24rpx;
}

.footer-btn {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24rpx;
    background: #fff;
    box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
    z-index: 100;
}
