.goods-list-container {
    background-color: #f5f5f5;
    min-height: 100vh;
    padding-bottom: 100rpx;
}

/* Filter Bar */
.filter-bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12rpx;
    padding: 24rpx;
}

.filter-item {
    display: flex;
    align-items: center;
    gap: 6rpx;
    padding: 10rpx 16rpx;
    background: #fff;
    border-radius: 999rpx;
    border: 1rpx solid #e5e6eb;
    font-size: 24rpx;
    color: #333;
}

.filter-item text {
    margin-right: 0;
}

.filter-clear {
    padding: 4rpx;
    color: #999;
}

.list-wrapper {
    padding: 24rpx;
}

.goods-card {
    display: flex;
    background: #fff;
    border-radius: 16rpx;
    padding: 24rpx;
    margin-bottom: 24rpx;
}

.goods-img {
    width: 160rpx;
    height: 160rpx;
    border-radius: 8rpx;
    background-color: #eee;
    margin-right: 24rpx;
}

.goods-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.goods-title {
    font-size: 28rpx;
    color: #333;
    font-weight: bold;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
}

.goods-detail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 24rpx;
}

.goods-price {
    color: #fa4126;
    font-size: 32rpx;
    font-weight: bold;
}

.goods-stock {
    color: #999;
}

.empty-tip {
    text-align: center;
    color: #999;
    margin-top: 100rpx;
}
