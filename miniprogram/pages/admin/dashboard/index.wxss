.dashboard-container {
    padding: 24rpx;
    background-color: #f5f5f5;
    min-height: 100vh;
}

.dashboard-section {
    background: #ffffff;
    border-radius: 16rpx;
    padding: 16rpx 12rpx 8rpx;
    box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
    margin-bottom: 20rpx;
}

.dashboard-title {
    font-size: 26rpx;
    font-weight: 600;
    color: #333;
    padding: 4rpx 8rpx 12rpx;
}

.dashboard-grid {
    margin: 0 4rpx 8rpx;
}
