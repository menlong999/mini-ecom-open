.dashboard-container {
    padding: 24rpx;
    background-color: var(--color-page);
    min-height: 100vh;
}

.dashboard-section {
    background: #ffffff;
    border-radius: 16rpx;
    padding: 16rpx 12rpx 8rpx;
    box-shadow: var(--shadow-card);
    margin-bottom: 20rpx;
}

.dashboard-title {
    font-size: 26rpx;
    font-weight: 600;
    color: var(--color-text);
    padding: 4rpx 8rpx 12rpx;
}

.dashboard-grid {
    margin: 0 4rpx 8rpx;
}
