.detail-container {
  padding: 24rpx;
  padding-bottom: 80rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.goods-item {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.goods-main {
  flex: 1;
}

.goods-title {
  color: #333;
  font-size: 26rpx;
  margin-bottom: 6rpx;
}

.goods-specs {
  color: #999;
  font-size: 22rpx;
}

.goods-aside {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  color: #333;
  font-size: 24rpx;
}

.goods-price {
  font-weight: 600;
}

.goods-qty {
  color: #666;
}

.info-line {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.proofs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.proof-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.t-textarea-wrapper {
  background: #f9f9f9;
  border-radius: 8rpx;
  padding: 12rpx;
}

.tips {
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.right-input .t-input__control,
.right-input .t-input__placeholder {
  text-align: right;
}

.action-bar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 24rpx;
}

.history-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-row {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #333;
}

.history-row.secondary {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #888;
}

.history-status {
  font-weight: 600;
}

.history-time {
  color: #999;
}

.history-operator {
  margin-right: 16rpx;
}

.history-remark {
  flex: 1;
  text-align: right;
}
