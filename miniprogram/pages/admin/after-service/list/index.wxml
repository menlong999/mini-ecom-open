<view class="service-list-container">
  <t-toast id="t-toast" />

  <view class="status-tabs">
    <view
      wx:for="{{statusTabs}}"
      wx:key="key"
      class="status-tab {{currentStatus === item.key ? 'active' : ''}}"
      bindtap="onStatusTabTap"
      data-key="{{item.key}}"
    >
      {{item.text}}
    </view>
  </view>

  <view class="search-bar">
    <t-input
      placeholder="售后单号搜索"
      value="{{keyword}}"
      bind:change="onKeywordChange"
      borderless="{{true}}"
      t-class="search-input"
    />
    <t-button size="small" theme="primary" bind:tap="onSearch">搜索</t-button>
  </view>

  <view class="list-wrapper">
    <block wx:for="{{serviceList}}" wx:key="_id">
      <view class="service-card">
        <view class="service-card__header">
          <text class="service-no">售后单号: {{item.rightsNo}}</text>
          <text class="service-status">{{item.statusDesc}}</text>
        </view>
        <view class="service-card__body">
          <view class="service-meta">
            <text>订单号: {{item.orderNo || '-'}}</text>
            <text>{{item.typeDesc}}</text>
          </view>
          <view class="service-meta">
            <text>申请时间: {{item.createdAtText || '-'}}</text>
            <text>退款金额: ¥{{item.amount || '0'}}</text>
          </view>
          <view class="service-goods-list">
            <view
              class="service-goods-item"
              wx:for="{{item.goodsList}}"
              wx:for-item="goods"
              wx:for-index="index"
              wx:key="index"
            >
              <view class="service-goods-main">
                <view class="service-goods-title">{{goods.title}}</view>
                <view class="service-goods-specs">规格: {{goods.specs || '-'}}</view>
              </view>
              <view class="service-goods-aside">
                <text class="service-goods-price">¥{{goods.price}}</text>
                <text class="service-goods-qty">x{{goods.quantity}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="service-card__actions">
          <t-button
            size="small"
            theme="primary"
            bind:tap="onDetailTap"
            data-rightsno="{{item.rightsNo}}"
          >
            {{item.actionText}}
          </t-button>
        </view>
      </view>
    </block>

    <view wx:if="{{!loading && serviceList.length === 0}}" class="empty-tip">暂无售后</view>
  </view>
</view>
