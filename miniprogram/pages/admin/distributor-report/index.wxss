.page {
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--color-page);
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  background: var(--color-page);
}

.selector-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.selector-value {
  flex: 1;
  font-size: 24rpx;
  color: var(--color-text);
  padding: 0 16rpx;
  text-align: right;
}

.selector-arrow {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.summary-bar {
  display: flex;
  gap: 12rpx;
  background: var(--color-page);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--color-border);
}

.summary-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.summary-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-warning);
}

.order-loading {
  padding: 16rpx 0;
}

.order-card {
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.order-header {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.order-amount {
  color: var(--color-warning);
}

.order-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 10rpx;
}

.order-address {
  background: var(--color-page);
  border-radius: 10rpx;
  padding: 12rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
}

.order-address-detail {
  margin-top: 6rpx;
  color: var(--color-text-secondary);
}

.order-goods-list {
  border-top: 1rpx solid var(--color-border);
  padding-top: 12rpx;
}

.order-goods-item {
  margin-bottom: 10rpx;
}

.order-goods-item:last-child {
  margin-bottom: 0;
}

.goods-title {
  font-size: 24rpx;
  color: var(--color-text);
}

.goods-specs {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.goods-meta {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.popup-panel {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 20rpx 32rpx;
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.popup-close {
  font-size: 32rpx;
  color: var(--color-text-muted);
}

.popup-search {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.popup-list {
  margin-top: 16rpx;
  max-height: 520rpx;
  overflow-y: auto;
}

.popup-loading {
  padding: 24rpx 0;
}

.popup-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.popup-item:last-child {
  border-bottom: none;
}

.popup-name {
  font-size: 24rpx;
  color: var(--color-text);
}

.popup-id {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

.popup-empty,
.empty {
  padding: 24rpx 0;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-muted);
}
