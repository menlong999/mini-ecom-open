.page {
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--color-page);
  min-height: 100vh;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: var(--shadow-card);
}

.summary-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

.summary-row .value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-warning);
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.table {
  border: 1rpx solid var(--color-border);
  border-radius: 12rpx;
  overflow: hidden;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid var(--color-border);
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.table-row:last-child {
  border-bottom: none;
}

.table-head {
  background: var(--color-page);
  font-weight: 600;
  color: var(--color-text);
}

.col {
  flex: 1;
}

.col.date {
  flex: 1.2;
}

.col.num {
  text-align: center;
}

.col.amount {
  text-align: right;
  color: var(--color-warning);
}

.loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  z-index: 99;
}

@media (max-width: 500px) {
  .summary-grid {
    grid-template-columns: 1fr;
  }
}
