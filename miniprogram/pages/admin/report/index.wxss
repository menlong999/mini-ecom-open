.page {
  padding: 24rpx;
  box-sizing: border-box;
  background: #f5f5f5;
  min-height: 100vh;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.summary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.04);
}

.summary-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666;
  margin-top: 6rpx;
}

.summary-row .value {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff5f15;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 12rpx;
}

.table {
  border: 1rpx solid #ececec;
  border-radius: 12rpx;
  overflow: hidden;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 24rpx;
  color: #444;
}

.table-row:last-child {
  border-bottom: none;
}

.table-head {
  background: #fafafa;
  font-weight: 600;
  color: #222;
}

.col {
  flex: 1;
}

.col.date {
  flex: 1.2;
}

.col.num {
  text-align: center;
}

.col.amount {
  text-align: right;
  color: #ff5f15;
}

.loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.6);
  z-index: 99;
}

@media (max-width: 500px) {
  .summary-grid {
    grid-template-columns: 1fr;
  }
}
