@import '../../../style/theme.wxss';

.invoice {
  height: 100vh;
  background: var(--color-page);
  position: relative;
  padding-top: 20rpx;

  --td-input-vertical-padding: 0;
}

.invoice-cell .t-cell__title {
  width: 144rpx;
  padding-right: 32rpx;
  flex: none !important;
}

.invoice .t-input__wrapper {
  margin: 0 !important;
}

.srcoll-view-wrap {
  margin-top: 20rpx;
}

.invoice .flex {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invoice .head-title {
  color: var(--color-text);
  font-size: 30rpx;
  font-weight: bold;
}

.invoice .btn-wrap {
  display: flex;
}

.invoice .btn-wrap .btn {
  width: 128rpx;
  background: var(--color-page);
  font-size: 24rpx;
  color: var(--color-text);
  margin-right: 22rpx;
  text-align: center;
  border-radius: 8rpx;
  position: relative;
  border: 2rpx solid var(--color-page);
}

.invoice .btn-wrap .active-btn {
  background-color: transparent;
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.invoice .title {
  width: 100%;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.invoice .invoice-label {
  display: flex;
}

.invoice .invoice-label .btn {
  width: 128rpx;
  background: var(--color-page);
  font-size: 24rpx;
  color: var(--color-text);
  margin-left: 22rpx;
  text-align: center;
  border-radius: 8rpx;
  border: 2rpx solid var(--color-page);
}

.invoice .invoice-label .active-btn {
  background-color: transparent;
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.invoice .invoice-label .wr-cell__title {
  font-size: 30rpx;
  color: var(--color-text);
  font-weight: bold;
}

.invoice .invoice-content {
  background: #fff;
  margin-top: 20rpx;
}

.invoice .invoice-content .addressTags {
  padding: 0 30rpx;
  height: 100rpx;
}

.invoice .invoice-content .addressTags .btn-wrap {
  display: flex;
}

.invoice .invoice-content .line {
  width: 720rpx;
  margin-left: 30rpx;
  background-color: var(--color-border);
  height: 1rpx;
}

.invoice .invoice-content .invoice-input {
  display: flex;
  padding: 0 30rpx;
  align-items: center;
  height: 100rpx;
  color: var(--color-text-secondary);
}

.invoice .invoice-content .invoice-input .title {
  color: var(--color-text);
  display: inline-block;
  width: 140rpx;
  margin-right: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.input-com {
  display: inline-block;
  flex: 1;
  font-size: 30rpx;
  font-weight: 400;
  line-height: 30rpx;
  padding: 0 !important;
  color: var(--color-text-secondary);
}

.input-com::after {
  border: none !important;
}

.invoice .invoice-content .invoice-input .wr-icon {
  font-size: 28rpx !important;
  margin-left: 20rpx;
}

.invoice .invoice-info {
  background: #fff;
  margin-top: 20rpx;
}

.invoice .invoice-info .info-con {
  padding: 0 30rpx;
  height: 100rpx;
}

.invoice .invoice-info .title {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 36rpx;
  padding: 0 30rpx 20rpx;
  box-sizing: border-box;
}

.invoice .invoice-know {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 400;
  color: var(--color-text-muted);
  padding: 20rpx 30rpx;
  line-height: 26rpx;
}

.invoice .invoice-know .icon {
  margin-left: 16rpx;
  font-size: 26rpx;
}

.invoice .dialog-invoice .dialog__message {
  padding: 0;
}

.invoice .dialog-invoice .dialog-info {
  max-height: 622rpx;
}

.invoice .dialog-invoice .info-wrap {
  padding: 0 18rpx;
}

.invoice .dialog-invoice .info .title {
  display: inline-block;
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-muted);
  line-height: 40rpx;
  margin-bottom: 40rpx;
  text-align: left;
}

.invoice .invoice-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #fff;
  width: 100%;
  padding: 0 20rpx;
  box-sizing: border-box;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.invoice .invoice-btn .invoice-btn-con {
  margin-top: 20rpx;
  display: inline-block;
  width: 100%;
  line-height: 80rpx;
  background: var(--color-primary);
  text-align: center;
  color: #fff;
  border-radius: 48rpx;
}

.cell-left {
  margin-right: 0 !important;
}

.cell-right {
  display: flex;
  justify-content: flex-start;
  width: 480rpx;
}

.addressTagsIndex-cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
}

.t-button {
  --td-button-default-color: var(--color-text);
  --td-button-primary-text-color: var(--color-primary);
}