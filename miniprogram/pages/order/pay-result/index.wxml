<t-navbar background="#ffffff" left-icon="slot" />
<view class="pay-result">
  <view class="pay-result-card">
    <view class="pay-status-icon">
      <t-icon name="check" size="56rpx" color="#4F7D5A" />
    </view>
    <view class="pay-status-text">支付成功</view>
    <view class="pay-status-desc">订单已提交，商家会尽快处理</view>
  </view>

  <view class="pay-summary">
    <view class="pay-summary-label">微信支付</view>
    <view class="pay-summary-amount">
      <price
        wx:if="{{totalPaid}}"
        price="{{totalPaid}}"
        wr-class="pay-money__price"
        decimalSmaller
        fill
        priceUnit="yuan"
      />
      <text wx:else>¥0.00</text>
    </view>
  </view>

  <view class="btn-wrapper">
    <t-button
      block
      theme="primary"
      t-class="status-btn status-btn-primary"
      size="large"
      data-type="orderList"
      bind:tap="onTapReturn"
      >查看订单</t-button
    >
    <t-button
      block
      theme="light"
      t-class="status-btn status-btn-secondary"
      size="large"
      data-type="home"
      bind:tap="onTapReturn"
      >返回首页</t-button
    >
  </view>
</view>
