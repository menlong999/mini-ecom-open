:host {
  background-color: #f5f5f5;
}

.list-loading {
  height: 100rpx;
}

.empty-wrapper {
  height: calc(100vh - 88rpx);
}

/* Cleaned up styles for manual layout */
.order-card {
  margin: 24rpx;
  padding: 24rpx 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #333;
}

.header__left {
  font-weight: bold;
}

.header__right {
  font-size: 26rpx;
  color: #fa4126;
  display: flex;
  align-items: center;
}

/* Goods Item Styles */
.goods-item {
  display: flex;
  padding: 16rpx 0;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
  background-color: #f5f5f5;
  overflow: hidden;
}

.goods-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-title {
  font-size: 28rpx;
  color: #333;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-specs {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 16rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.goods-num {
  font-size: 24rpx;
  color: #999;
}

.status-desc {
  box-sizing: border-box;
  padding: 22rpx 20rpx;
  font-size: 26rpx;
  line-height: 1.3;
  text-align: left;
  color: #333333;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  word-wrap: break-word;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
}

.more-slot {
  margin-top: 16rpx;
}

.t-button {
  --td-button-default-color: #000;
  --td-button-primary-text-color: #fa4126;
}