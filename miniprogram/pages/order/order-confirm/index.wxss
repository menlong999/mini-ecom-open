.order-sure {
  box-sizing: border-box;
  background: var(--color-page);
  padding: 24rpx 0 calc(env(safe-area-inset-bottom) + 136rpx);
  min-height: 100vh;
}

.order-sure .wx-pay-cover {
  position: fixed;
  left: 0;
  bottom: 0;
  right: 0;
  z-index: 10;
  background: #fff;
  height: 112rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

.order-sure .wx-pay-cover .wx-pay {
  width: 100%;
  height: 100rpx;
  box-sizing: border-box;
  padding: 0rpx 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-sure .wx-pay-cover .wx-pay .price {
  color: var(--color-price);
  font-weight: bold;
  font-size: 63rpx;
  line-height: 88rpx;
}

.order-sure .wx-pay-cover .wx-pay .submit-btn {
  height: 80rpx;
  width: 240rpx;
  border-radius: 40rpx;
  background-color: var(--color-primary);
  color: #ffffff;
  line-height: 80rpx;
  font-weight: bold;
  font-size: 28rpx;
  text-align: center;
}

.order-sure .wx-pay-cover .wx-pay .btn-gray {
  background: var(--color-border);
}

.order-wrapper .store-wrapper {
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  line-height: 40rpx;
  color: var(--color-text);
  background-color: #ffffff;
}

.order-wrapper .store-wrapper .store-logo {
  margin-right: 16rpx;
}

.order-wrapper .goods-wrapper {
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  font-size: 24rpx;
  line-height: 32rpx;
  color: var(--color-text-muted);
  background-color: #ffffff;
}

.goods-wrapper .goods-image {
  width: 176rpx;
  height: 176rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.goods-wrapper .goods-content {
  flex: 1;
}

.goods-wrapper .goods-content .goods-title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 28rpx;
  line-height: 40rpx;
  margin-bottom: 12rpx;
  color: var(--color-text);
  margin-right: 16rpx;
}

.goods-wrapper .goods-right {
  min-width: 128rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.goods-right .goods-price {
  color: var(--color-text);
  font-size: 32rpx;
  line-height: 48rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.goods-right .goods-num {
  text-align: right;
}

.order-sure .pay-detail {
  background-color: #ffffff;
  padding: 16rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.order-sure .pay-detail .pay-item {
  width: 100%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  line-height: 36rpx;
  color: var(--color-text-secondary);
}

.order-sure .pay-detail .pay-item .pay-item__right {
  color: var(--color-text);
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  max-width: 400rpx;
}

.order-sure .pay-detail .pay-item .pay-item__right .pay-remark {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  max-width: 400rpx;
  text-overflow: ellipsis;
  overflow: hidden;
}

.order-sure .pay-detail .pay-item .font-bold {
  font-weight: bold;
}

.order-sure .pay-detail .pay-item .primary {
  color: var(--color-primary);
}

.add-notes .add-notes__content {
  --td-textarea-background-color: var(--color-page);
}

.add-notes .t-textarea__placeholder {
  color: var(--color-text-muted);
}

.add-notes .add-notes__textarea__font {
  font-size: 26rpx;
}

.add-notes .add-notes__textarea {
  margin-top: 32rpx;
}

.order-sure .add-notes .dialog__message {
  border-radius: 8rpx;
}

.order-sure .add-notes .dialog__button-cancel::after {
  border-right: 0;
}

.order-sure .amount-wrapper {
  width: 100%;
  box-sizing: border-box;
  background-color: #ffffff;
  padding: 0rpx 32rpx;
  height: 96rpx;
}

.order-sure .pay-amount {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: var(--color-text);
  position: relative;
}

.order-sure .pay-amount::after {
  position: absolute;
  content: ' ';
  top: 0;
  left: 0;
  width: 200%;
  height: 200%;
  transform: scale(0.5);
  transform-origin: 0 0;
  border-top: 2rpx solid var(--color-page);
}

.order-sure .pay-amount .order-num {
  color: var(--color-text-muted);
  padding-right: 8rpx;
}

.order-sure .pay-amount .total-price {
  font-size: 36rpx;
  color: var(--color-price);
  font-weight: bold;
  padding-left: 8rpx;
}

.top-line {
  width: 100%;
  height: 2rpx;
  background: var(--color-border);
  display: block;
}

/* 商品失效弹窗样式 */
.goods-fail {
  background: #fff;
  border-radius: 20rpx 20rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.goods-fail .title {
  text-align: center;
  font-weight: bold;
  font-size: 32rpx;
  padding-top: 40rpx;
}

.goods-fail .info {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-align: center;
  padding: 20rpx 40rpx;
}

.goods-fail-list {
  max-height: 500rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.goods-fail-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-page);
}

.goods-fail-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  margin-right: 20rpx;
}

.goods-fail-content {
  flex: 1;
}

.goods-fail-title {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  line-clamp: 2;
  overflow: hidden;
}

.goods-fail-specs {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.goods-fail-right {
  text-align: right;
  margin-left: 20rpx;
}

.goods-fail-price {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}

.goods-fail-num {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.goods-fail-btns {
  display: flex;
  padding: 32rpx;
  justify-content: space-between;
}

.fail-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  border: 2rpx solid var(--color-border);
  margin: 0 12rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.fail-btn.primary {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}
