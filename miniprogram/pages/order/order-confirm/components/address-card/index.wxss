.address-card {
  background: #fff;
  margin: 0rpx 0rpx 24rpx;
}
.address-card .wr-cell__title {
  color: var(--color-text-muted);
  margin-left: 6rpx;
}
.address-card .order-address {
  display: flex;
  width: 100%;
}
.address-card .order-address .address-content {
  flex: 1;
}
.order-address .address__right {
  align-self: center;
}
.address-card .order-address .title {
  display: flex;
  align-items: center;
  height: 40rpx;
  font-size: 28rpx;
  font-weight: normal;
  color: var(--color-text-muted);
  line-height: 40rpx;
}
.address-card .order-address .title .address-tag {
  width: 52rpx;
  height: 29rpx;
  border: 1rpx solid var(--color-primary);
  background-color: var(--color-primary-light);
  text-align: center;
  line-height: 29rpx;
  border-radius: 8rpx;
  color: var(--color-primary);
  font-size: 20rpx;
  margin-right: 12rpx;
}
.address-card .order-address .detail {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
  line-height: 48rpx;
  margin: 8rpx 0;
}
.address-card .order-address .info {
  height: 40rpx;
  font-size: 28rpx;
  font-weight: normal;
  color: var(--color-text);
  line-height: 40rpx;
}
.address-card .top-line {
  width: 100%;
  height: 2rpx;
  background: var(--color-border);
  display: block;
}
