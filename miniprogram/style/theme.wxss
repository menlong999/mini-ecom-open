/*
 * 全局设计 Token
 *
 * 这是开源版本的唯一设计 token 来源。所有页面 / 组件应只使用这里定义的
 * CSS 变量，不要在页面 wxss 里写死颜色、字号、圆角、阴影。
 *
 * 风格关键词：素雅、克制、清洁、可信赖、有温度，但不沉重。
 * - 不做黑白灰殡葬感
 * - 不做红橙促销电商感
 * - 价格 / 金额使用 --color-price（茶褐），不用红
 * - 主交互、链接、选中态使用 --color-primary（松青灰绿）
 * - 危险 / 错误 / 退款异常才使用 --color-danger
 *
 * 管理端页面统一用 --admin-* 覆盖主色与背景，保持低噪声的列表 / 表单形态。
 */
page {
  /* 颜色 - 品牌 / 状态 */
  --color-primary: #4f6f64;
  --color-primary-pressed: #405c52;
  --color-primary-light: #eef3ef;
  --color-price: #8a5a44;
  --color-success: #4f7d5a;
  --color-warning: #b07a3c;
  --color-danger: #b84a42;
  --color-info: #4e667a;
  /* 弱化背景，用于轻提示条 / 标签 */
  --color-success-soft: #e9efe9;
  --color-warning-soft: #f6efe2;
  --color-danger-soft: #f5e3e1;
  --color-info-soft: #e9eef3;

  /* 颜色 - 文字 */
  --color-text: #202421;
  --color-text-secondary: #616961;
  --color-text-muted: #9aa19a;
  --color-text-disabled: #c9cec7;
  --color-text-inverse: #ffffff;

  /* 颜色 - 表面 / 背景 */
  --color-surface: #ffffff;
  --color-surface-soft: #fafbf9;
  --color-page: #f6f7f5;
  --color-page-soft: #fafbf9;

  /* 颜色 - 边框 / 分隔 / 蒙层 */
  --color-border: #e3e7e1;
  --color-divider: #ecefea;
  --color-mask: rgba(32, 36, 33, 0.45);

  /* 圆角 */
  --radius-xs: 6rpx;
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-pill: 999rpx;

  /* 阴影 - 克制使用，仅用于浮层 / 重要分层 */
  --shadow-card: 0 8rpx 24rpx rgba(32, 36, 33, 0.04);
  --shadow-popover: 0 12rpx 32rpx rgba(32, 36, 33, 0.08);
  --shadow-bar: 0 -4rpx 16rpx rgba(32, 36, 33, 0.04);

  /* 间距 */
  --space-1: 8rpx;
  --space-2: 16rpx;
  --space-3: 24rpx;
  --space-4: 32rpx;
  --space-5: 40rpx;
  --space-6: 48rpx;
  --space-8: 64rpx;

  /* 字号 / 行高 */
  --font-size-xs: 22rpx;
  --font-size-sm: 24rpx;
  --font-size-base: 28rpx;
  --font-size-md: 30rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-2xl: 40rpx;
  --font-size-price: 44rpx;
  --line-height-tight: 1.3;
  --line-height-base: 1.5;
  --line-height-loose: 1.7;
  --font-weight-regular: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-family-base: -apple-system, BlinkMacSystemFont, 'PingFang SC',
    'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif;

  /* 动效 */
  --motion-duration-fast: 120ms;
  --motion-duration-base: 200ms;
  --motion-duration-slow: 320ms;
  --motion-ease: cubic-bezier(0.4, 0, 0.2, 1);

  /* 管理端令牌 - 与用户端共享文字 / 圆角 / 阴影 / 间距 / 字号体系 */
  --admin-primary: #4e667a;
  --admin-primary-pressed: #3f5364;
  --admin-primary-light: #edf3f6;
  --admin-page: #f4f6f8;
  --admin-border: #dfe6eb;

  min-height: 100%;
  color: var(--color-text);
  background: var(--color-page);
  font-family: var(--font-family-base);
}

.dashboard-container,
.home-config-page,
.service-list-container,
.detail-container,
.stock-container,
.category-container,
.goods-list-container,
.edit-container,
.order-list-container,
.ship-container,
view.page {
  --color-primary: var(--admin-primary);
  --color-primary-pressed: var(--admin-primary-pressed);
  --color-primary-light: var(--admin-primary-light);
  --color-page: var(--admin-page);
  --color-border: var(--admin-border);
}

page,
view,
text,
input,
textarea,
button {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.t-input {
  --td-input-bg-color: var(--color-page-soft);
  --td-input-border-color: var(--color-border);
  --td-input-placeholder-text-color: var(--color-text-muted);
  --td-input-text-color: var(--color-text);
}

.t-tab-bar {
  --td-tab-bar-color: var(--color-text-muted);
  --td-tab-bar-active-color: var(--color-primary);
  --td-tab-bar-bg-color: rgba(255, 255, 255, 0.96);
}

.t-cascader {
  --td-cascader-active-color: var(--color-primary);
}

.t-switch {
  --td-switch-checked-color: var(--color-primary);
}

.t-button {
  --td-button-font-weight: 500;
  --td-button-medium-font-size: 30rpx;
  --td-button-default-color: #fff;
  --td-button-default-bg-color: var(--color-primary);
  --td-button-default-border-color: var(--color-primary);
  --td-button-default-disabled-color: #fff;
  --td-button-default-disabled-bg: #c9cec7;
  --td-button-default-disabled-border-color: #c9cec7;
  --td-button-default-active-bg-color: var(--color-primary-pressed);
  --td-button-default-active-border-color: var(--color-primary-pressed);
  --td-button-primary-bg-color: var(--color-primary);
  --td-button-primary-border-color: var(--color-primary);
  --td-button-primary-active-bg-color: var(--color-primary-pressed);
  --td-button-primary-active-border-color: var(--color-primary-pressed);
  --td-button-light-color: var(--color-primary);
  --td-button-light-bg-color: var(--color-primary-light);
  --td-button-light-border-color: var(--color-primary-light);
}

.t-textarea {
  --td-textarea-background-color: var(--color-page-soft);
  --td-textarea-placeholder-color: var(--color-text-muted);
}

.t-checkbox {
  --td-checkbox-icon-checked-color: var(--color-primary);
}

.t-tabs {
  --td-tab-item-active-color: var(--color-primary);
  --td-tab-track-color: var(--color-primary);
}

.t-search {
  --td-search-bg-color: var(--color-surface);
  --td-search-input-bg-color: var(--color-page-soft);
}

.dialog__button-confirm {
  color: var(--color-primary) !important;
}

.dialog__button-cancel {
  color: var(--color-text-muted) !important;
}
